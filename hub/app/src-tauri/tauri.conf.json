{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hub",
  "version": "0.1.0",
  "identifier": "dev.hub.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      { "title": "Terminal Hub", "width": 1200, "height": 800 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["binaries/hub", "binaries/hub-daemon", "binaries/hub-relay"]
  }
}
